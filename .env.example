# Supabase — copia este archivo a .env y completa los valores.
# Local (supabase start imprime estos valores):
SUPABASE_URL="http://127.0.0.1:54321"
SUPABASE_ANON_KEY=""
# Service role: solo para el collector / edge functions (nunca en el cliente web).
SUPABASE_SERVICE_ROLE_KEY=""

# Scraper — identificable y con contacto, segun docs/SCRAPING.md
SCRAPER_USER_AGENT="PreciosGT-Bot/0.1 (+https://github.com/chofito/precios-gt; contacto@example.com)"
# Rate limit entre requests a una misma tienda (ms)
SCRAPER_MIN_DELAY_MS="3000"

# Next.js (apps/web) — variables publicas expuestas al browser
NEXT_PUBLIC_SUPABASE_URL="http://127.0.0.1:54321"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
