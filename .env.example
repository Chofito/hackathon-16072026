# Supabase — copia a .env (raíz) y apps/web/.env.local
# Preferí el proyecto Cloud (Dashboard → Settings → API). Docker/local es opcional.
SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
SUPABASE_ANON_KEY=""
# Service role: solo collector / edge functions (nunca en el cliente web).
SUPABASE_SERVICE_ROLE_KEY=""

# Scraper — identificable y con contacto, segun docs/SCRAPING.md
SCRAPER_USER_AGENT="GuateOfertasBot/0.1 (+https://github.com/chofito/guateofertas; contacto@example.com)"
SCRAPER_MIN_DELAY_MS="3000"

# Next.js (apps/web) — lecturas SSR con anon key + RLS
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
